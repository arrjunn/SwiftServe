# ═══════════════════════════════════════════════
# SwiftServe — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════

# ─── Supabase (Required for production) ───────
# Get from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Cloud server keys (Settings → API → service_role key)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase DB connection (Settings → Database → Connection string)
SUPABASE_DB_URL=postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ─── OR: Direct PostgreSQL (local dev) ────────
# DATABASE_URL=postgresql://localhost:5432/swiftserve

# ─── Cloud Server ─────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=generate-a-random-64-char-string-here
CORS_ORIGIN=http://localhost:5173

# ─── Razorpay (Card Payments) ─────────────────
# RAZORPAY_KEY_ID=rzp_live_xxxxx
# RAZORPAY_KEY_SECRET=xxxxx

# ─── Zomato ───────────────────────────────────
# ZOMATO_WEBHOOK_SECRET=xxxxx
# ZOMATO_API_KEY=xxxxx

# ─── Swiggy ───────────────────────────────────
# SWIGGY_WEBHOOK_SECRET=xxxxx
# SWIGGY_API_KEY=xxxxx

# ─── WhatsApp Business API ────────────────────
# WHATSAPP_PHONE_NUMBER_ID=xxxxx
# WHATSAPP_ACCESS_TOKEN=xxxxx
# WHATSAPP_VERIFY_TOKEN=my-verify-token
# WHATSAPP_APP_SECRET=xxxxx

# ─── Thermal Printer ──────────────────────────
# PRINTER_IP=192.168.1.100
# PRINTER_PORT=9100

# ─── PII Encryption (DPDP) ────────────────────
# PII_ENCRYPTION_KEY=generate-a-random-32-char-key
